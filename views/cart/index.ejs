<!DOCTYPE html>
<html>

<head>

    <title>My Cart</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

    <div class="container mt-5">

        <h2 class="mb-4">
            My Shopping Cart
        </h2>

        <% if(!cart || cart.items.length===0){ %>

            <div class="alert alert-info">

                Your cart is empty.

            </div>

            <a href="/ecom/products" class="btn btn-primary">

                Continue Shopping

            </a>

            <% } else { %>

                <% let grandTotal=0; %>

                    <table class="table table-bordered bg-white shadow">

                        <thead>

                            <tr>

                                <th>Image</th>

                                <th>Product</th>

                                <th>Price</th>

                                <th>Quantity</th>

                                <th>Total</th>

                            </tr>

                        </thead>

                        <tbody>

                            <% cart.items.forEach(item=>{ %>

                                <% let total=item.product.price*item.quantity; grandTotal+=total; %>

                                    <tr>

                                        <td width="180">

                                            <img src="<%= item.product.image.url %>" width="150" height="120"
                                                style="object-fit:cover;">

                                        </td>

                                        <td>

                                            <h5>

                                                <%= item.product.title %>

                                            </h5>

                                        </td>

                                        <td>

                                            ₹ <%= item.product.price %>

                                        </td>

                                        <td>

                                            <%= item.quantity %>

                                        </td>

                                        <td>

                                            ₹ <%= total %>

                                        </td>
                                        <td>

                                            <form action="/ecom/cart/decrease/<%= item.product._id %>?_method=PUT"
                                                method="POST" class="d-inline">

                                                <button class="btn btn-sm btn-danger">
                                                    -
                                                </button>

                                            </form>

                                            <strong class="mx-2">
                                                <%= item.quantity %>
                                            </strong>

                                            <form action="/ecom/cart/increase/<%= item.product._id %>?_method=PUT"
                                                method="POST" class="d-inline">

                                                <button class="btn btn-sm btn-success">
                                                    +
                                                </button>

                                            </form>

                                        </td>
                                        <td>

                                            <form action="/ecom/cart/remove/<%= item.product._id %>?_method=DELETE"
                                                method="POST">

                                                <button class="btn btn-danger btn-sm">

                                                    Remove

                                                </button>

                                            </form>

                                        </td>

                                    </tr>

                                    <% }) %>

                        </tbody>

                    </table>

                    <div class="text-end">

                        <h3>

                            Grand Total :
                            ₹ <%= grandTotal %>

                        </h3>

                        <a href="/ecom/products" class="btn btn-secondary">

                            Continue Shopping

                        </a>

                        <form action="/ecom/order/checkout" method="POST">

                            <button class="btn btn-success">
                                Checkout
                            </button>

                        </form>

                    </div>

                    <% } %>

    </div>

</body>

</html>