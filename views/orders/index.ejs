<!DOCTYPE html>
<html>

<head>

    <title>My Orders</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<h2 class="mb-4">
    📦 My Orders
</h2>

<% if(orders.length===0){ %>

<div class="alert alert-info">

You haven't placed any orders yet.

</div>

<a href="/ecom/products" class="btn btn-primary">

Start Shopping

</a>

<% } else { %>

<% orders.forEach(order=>{ %>

<div class="card shadow mb-4">

<div class="card-header d-flex justify-content-between">

<div>

<strong>

Order ID:

</strong>

<%= order._id %>

</div>

<div>

<strong>

Status:

</strong>

<span class="badge bg-success">

<%= order.status %>

</span>

</div>

</div>

<div class="card-body">

<p>

<strong>

Order Date:

</strong>

<%= order.createdAt.toDateString() %>

</p>

<table class="table">

<thead>

<tr>

<th>Product</th>

<th>Price</th>

<th>Quantity</th>

<th>Total</th>

</tr>

</thead>

<tbody>

<% order.items.forEach(item=>{ %>

<tr>

<td>

<%= item.product.title %>

</td>

<td>

₹ <%= item.price %>

</td>

<td>

<%= item.quantity %>

</td>

<td>

₹ <%= item.price * item.quantity %>

</td>

</tr>

<% }) %>

</tbody>

</table>

<h4 class="text-end">

Grand Total :

₹ <%= order.totalAmount %>

</h4>

</div>

</div>

<% }) %>

<% } %>

</div>

</body>

</html>