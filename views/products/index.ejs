<!DOCTYPE html>
<html>

<head>

    <title>Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="d-flex justify-content-between align-items-center mb-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

    <h2>All Products</h2>

    <div>
        <a href="/ecom/order" class="btn btn-info me-2">
        📦 My Orders
        </a>
        
        <a href="/ecom/cart" class="btn btn-primary me-2">
            🛒 My Cart
        </a>

        <a href="/ecom/products/new" class="btn btn-success">
            + Add Product
        </a>

    </div>

</div>

</div>

<div class="row">

<% products.forEach(product=>{ %>

<div class="col-md-4 mb-4">

<div class="card shadow">

<img
src="<%= product.image.url %>"
class="card-img-top"
height="250"
style="object-fit:cover;"
>

<div class="card-body">

<h5><%= product.name %></h5>

<p>

₹ <%= product.price %>

</p>

<a
href="/ecom/products/<%= product._id %>"
class="btn btn-primary"
>

View Details

</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>

</body>

</html>