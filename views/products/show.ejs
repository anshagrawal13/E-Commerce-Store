<!DOCTYPE html>
<html>

<head>

<title>Product Details</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="card shadow p-4">

<img
src="<%= product.image.url %>"
height="350"
style="object-fit:cover;"
>

<h2 class="mt-3">

<%= product.name %>

</h2>

<p>

<%= product.description %>

</p>

<h4>

₹ <%= product.price %>

</h4>

<h5>

Stock :

<%= product.stock %>

</h5>

<h6>

Category :

<%= product.category %>

</h6>

<div class="mt-4">

    <a href="/ecom/products/<%= product._id %>/edit"
       class="btn btn-warning">
        Edit
    </a>

    <form action="/ecom/products/<%= product._id %>?_method=DELETE"
          method="POST"
          class="d-inline">
        <button class="btn btn-danger">
            Delete
        </button>
    </form>

    <form action="/ecom/cart/add/<%= product._id %>" method="POST">

    <button class="btn btn-primary">
        🛒 Add to Cart
    </button>

</form>

</div>



</div>

</div>

</body>

</html>